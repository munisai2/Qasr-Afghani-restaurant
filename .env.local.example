# Found in sanity.io/manage → your project → API tab
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET=""
NEXT_PUBLIC_SANITY_API_VERSION=""

# Generate at sanity.io/manage → API → Tokens
# Read token (Viewer role is sufficient)
SANITY_API_READ_TOKEN=""

# Write token — Editor role required (for saving orders to Sanity)
SANITY_API_WRITE_TOKEN=""

# Resend — get free API key at resend.com (no credit card needed)
# onboarding@resend.dev works on free tier without domain verification
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Owner email — orders and catering quotes are sent HERE (can be Gmail)
OWNER_NOTIFICATION_EMAIL=""

# Set to "true" to enable email sending
RESEND_ENABLED="false"

# Restaurant phone number — shown on error/404 pages
NEXT_PUBLIC_RESTAURANT_PHONE=""
NEXT_PUBLIC_RESTAURANT_NAME=""

# Cloudflare Turnstile — free at dash.cloudflare.com → Turnstile
# For local development, use Cloudflare's test keys:
#   Site key:   1x00000000000000000000AA   (always passes)
#   Secret key: 1x0000000000000000000000000000000AA (always passes)
NEXT_PUBLIC_TURNSTILE_SITE_KEY="your_site_key_here"
TURNSTILE_SECRET_KEY="your_secret_here"

# Public site URL (for sitemap, robots.txt, structured data)
NEXT_PUBLIC_SITE_URL=""
